# =============================================================================
# Personal Finance Tracker - Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/financetracker

# -----------------------------------------------------------------------------
# Authentication - Better Auth (Required)
# -----------------------------------------------------------------------------
# Generate a 32+ character secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-32-character-secret-here
BETTER_AUTH_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Application Settings (Required)
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# OAuth Providers (Optional)
# Uncomment and set these to enable OAuth authentication
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# -----------------------------------------------------------------------------
# Email/SMTP (Optional)
# Required for password reset and email notifications
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------
# VITE_ANALYTICS_ID=your-analytics-id

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
# ENABLE_BETA_FEATURES=false
# ENABLE_EXPORT_NOTIFICATIONS=true

# -----------------------------------------------------------------------------
# Alerting / Monitoring (Optional)
# -----------------------------------------------------------------------------
# Telegram Bot Configuration
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-telegram-chat-id
